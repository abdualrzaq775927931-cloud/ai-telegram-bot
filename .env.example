# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Database URL
# For SQLite (local development): sqlite:///poll_bot.db
# For PostgreSQL (Railway): postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///poll_bot.db

# Super Admin Telegram User IDs (comma-separated)
# Example: 12345678,87654321
ADMIN_IDS=
